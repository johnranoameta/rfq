# Historical match scoring weight overrides (optional)
# Copy values into .env.local only when tuning behavior.

RFQ_MATCH_W_MATERIAL=20
RFQ_MATCH_W_PROGRAM=14
RFQ_MATCH_W_PROCESS=16
RFQ_MATCH_W_CUSTOMER=6
RFQ_MATCH_W_PART_SUBSTRING=8
RFQ_MATCH_W_EXACT_PN=26
RFQ_MATCH_W_NAME_SIM_HIGH=8
RFQ_MATCH_W_NAME_SIM_MED=4
RFQ_MATCH_W_SPEC_SIM_HIGH=8
RFQ_MATCH_W_SPEC_SIM_MED=4
RFQ_MATCH_W_FEATURE_SIM_HIGH=6
RFQ_MATCH_W_FEATURE_SIM_MED=3
RFQ_MATCH_W_THICK_MATCH=6
RFQ_MATCH_W_THICK_CLOSE=3
RFQ_MATCH_W_VOL_SIMILAR=6
